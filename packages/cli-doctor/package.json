{
  "name": "@percy/cli-doctor",
  "version": "1.31.13",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/percy/cli",
    "directory": "packages/cli-doctor"
  },
  "publishConfig": {
    "access": "public",
    "tag": "latest"
  },
  "engines": {
    "node": ">=14"
  },
  "files": [
    "dist"
  ],
  "main": "./dist/index.js",
  "type": "module",
  "exports": {
    ".": "./dist/index.js"
  },
  "scripts": {
    "build": "node ../../scripts/build",
    "lint": "eslint --ignore-path ../../.gitignore .",
    "readme": "percy-cli-readme",
    "test": "node ../../scripts/test",
    "test:coverage": "yarn test --coverage"
  },
  "@percy/cli": {
    "commands": [
      "./dist/doctor.js"
    ]
  },
  "dependencies": {
    "@percy/cli-command": "1.31.13",
    "@percy/client": "1.31.13",
    "@percy/config": "1.31.13",
    "@percy/core": "1.31.13",
    "@percy/env": "1.31.13",
    "@percy/logger": "1.31.13",
    "@percy/monitoring": "1.31.13",
    "minimatch": "^9.0.0",
    "ws": "^8.17.1"
  }
}
